---
// Solution.astro — DS-05
interface Props {
  product?: 'digiscaff' | 'digiperim';
}
const { product } = Astro.props;
const showDigiScaff = !product || product === 'digiscaff';
const showDigiPerim = !product || product === 'digiperim';
const showHeader = !product;
---

<section id="solution" class="relative bg-navy py-20 md:py-[120px]">
  <div class="max-w-content mx-auto px-6 md:px-12">

    {showHeader && (
      <div class="reveal mb-20">
        <p class="font-mono font-semibold text-[18px] text-cyan uppercase tracking-[0.2em] mb-4">THE SOLUTION</p>
        <h2 class="font-grotesk font-bold text-off-white mb-5" style="font-size: clamp(36px, 5vw, 56px); letter-spacing: -0.02em; max-width: 680px;">
          Two products. Every construction site.
        </h2>
        <p class="font-grotesk text-mid-grey text-lg" style="max-width: 620px; line-height: 1.65;">
          DigiScaff mounts on scaffold structures. DigiPerim integrates into perimeter hoardings. Between them, they cover every deployment opportunity on every construction site in DigiSite's network.
        </p>
      </div>
    )}

    <!-- Product cards -->
    <div class:list={[product ? '' : 'grid grid-cols-1 lg:grid-cols-2 gap-6']}>

      {showDigiScaff && (
      <div class="reveal border border-cyan/[0.15] rounded-md bg-section overflow-hidden">
        <!-- Product image -->
        <div class="relative h-[300px] md:h-[400px] bg-navy overflow-hidden">
          <img
            src="/digiscaff-product-new.jpeg"
            alt="DigiScaff — digital LED screen with canvas wrap on scaffolding in a UK city centre"
            width="1536"
            height="1024"
            loading="lazy"
            class="w-full h-full object-cover object-center"
          />
          <!-- Fade to card background -->
          <div class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #0F2035);"></div>
        </div>

        <div class="px-6 md:px-9 pb-10">
          <p class="font-mono font-semibold text-[13px] uppercase tracking-[0.2em] text-cyan/60 mt-6">PRODUCT 01</p>
          <h3 class="font-grotesk font-bold text-white text-4xl mt-2" style="letter-spacing: -0.02em;">DigiScaff</h3>
          <p class="font-grotesk text-mid-grey text-[16px] mt-2 mb-7" style="line-height: 1.5;">
            High-brightness LED screens on construction scaffolding.
          </p>

          <!-- Spec strip -->
          <div class="flex gap-8 mb-6 flex-wrap">
            <div>
              <span class="font-mono font-semibold text-lg text-cyan">9,000 nits</span>
              <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mt-1">BRIGHTNESS</p>
            </div>
            <div>
              <span class="font-mono font-semibold text-lg text-cyan">33m&sup2;</span>
              <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mt-1">STANDARD LARGE FORMAT</p>
            </div>
            <div>
              <span class="font-mono font-semibold text-lg text-cyan">IP66</span>
              <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mt-1">WEATHERPROOF RATING</p>
            </div>
          </div>

          <div class="h-px bg-cyan/10 mb-6"></div>

          <p class="font-grotesk text-[15px] text-mid-grey mb-6" style="line-height: 1.7;">
            DigiScaff mounts directly onto existing scaffold structures using a key clamp sub-frame and EN74 scaffold couplers &mdash; no welding, no permanent fixing. Screens are surrounded by a printed canvas wrap that tensiones onto the frame's outer tube, presenting a clean, professional frontage. The rig is a reusable asset, recovered and redeployed across multiple sites.
          </p>

          <!-- Size config table -->
          <div class="font-mono text-[12px] mb-6">
            <div class="flex gap-6 text-mid-grey/70 uppercase tracking-[0.1em] text-[10px] font-semibold mb-2">
              <span class="w-28">Configuration</span>
              <span class="w-32">Dimensions</span>
              <span>Area</span>
            </div>
            <div class="flex gap-6 text-off-white py-2 border-t border-white/[0.06]">
              <span class="w-28">Small</span>
              <span class="w-32">2.88m &times; 1.92m</span>
              <span>5.5m&sup2;</span>
            </div>
            <div class="flex gap-6 text-off-white py-2 border-t border-white/[0.06]">
              <span class="w-28">Large</span>
              <span class="w-32">8.64m &times; 3.84m</span>
              <span>33.2m&sup2;</span>
            </div>
          </div>

          <p class="font-grotesk font-medium text-[13px] text-cyan">
            &rarr; Deploys on: scaffold structures on any active construction site.
          </p>
        </div>
      </div>

      )}

      {showDigiPerim && (
      <div class="reveal border border-cyan/[0.15] rounded-md bg-section overflow-hidden">
        <!-- Product image -->
        <div class="relative h-[300px] md:h-[400px] bg-navy overflow-hidden">
          <img
            src="/digiperim-night.jpeg"
            alt="DigiPerim — digital LED screens integrated into site perimeter hoardings at night"
            width="1536"
            height="1024"
            loading="lazy"
            class="w-full h-full object-cover object-center"
          />
          <!-- Fade to card background -->
          <div class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #0F2035);"></div>
        </div>

        <div class="px-6 md:px-9 pb-10">
          <p class="font-mono font-semibold text-[13px] uppercase tracking-[0.2em] text-cyan/60 mt-6">PRODUCT 02</p>
          <h3 class="font-grotesk font-bold text-white text-4xl mt-2" style="letter-spacing: -0.02em;">DigiPerim</h3>
          <p class="font-grotesk text-mid-grey text-[16px] mt-2 mb-7" style="line-height: 1.5;">
            Digital screens integrated into site perimeter hoardings.
          </p>

          <!-- Spec strip -->
          <div class="flex gap-8 mb-6 flex-wrap">
            <div>
              <span class="font-mono font-semibold text-lg text-cyan">8,000 nits</span>
              <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mt-1">BRIGHTNESS</p>
            </div>
            <div>
              <span class="font-mono font-semibold text-lg text-cyan">5.5m&sup2;</span>
              <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mt-1">STANDARD PANEL</p>
            </div>
            <div>
              <span class="font-mono font-semibold text-lg text-cyan">IP65</span>
              <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mt-1">WEATHERPROOF RATING</p>
            </div>
          </div>

          <div class="h-px bg-cyan/10 mb-6"></div>

          <p class="font-grotesk text-[15px] text-mid-grey mb-6" style="line-height: 1.7;">
            DigiPerim installs on any site perimeter &mdash; not just scaffolded sites. The screen sits inside a custom-designed weatherproof enclosure bolted onto a lightweight perimeter framework. Full front-access maintenance means panels are serviceable without rear access. Every construction site has a perimeter. DigiPerim ensures every site in DigiSite's network generates revenue from day one of the build &mdash; before scaffold is even erected.
          </p>

          <!-- Size config table -->
          <div class="font-mono text-[12px] mb-6">
            <div class="flex gap-6 text-mid-grey/70 uppercase tracking-[0.1em] text-[10px] font-semibold mb-2">
              <span class="w-28">Configuration</span>
              <span class="w-32">Dimensions</span>
              <span>Area</span>
            </div>
            <div class="flex gap-6 text-off-white py-2 border-t border-white/[0.06]">
              <span class="w-28">Single bay</span>
              <span class="w-32">2.88m &times; 0.96m</span>
              <span>2.8m&sup2;</span>
            </div>
            <div class="flex gap-6 text-off-white py-2 border-t border-white/[0.06]">
              <span class="w-28">Standard</span>
              <span class="w-32">2.88m &times; 1.92m</span>
              <span>5.5m&sup2;</span>
            </div>
          </div>

          <p class="font-grotesk font-medium text-[13px] text-amber">
            &rarr; Deploys on: any site perimeter hoarding &mdash; scaffolded or not.
          </p>
        </div>
      </div>
      )}
    </div>

    <!-- Shared infrastructure strip -->
    <div class="reveal mt-16 border-t border-b border-cyan/10 bg-cyan/[0.04] py-10 -mx-6 md:-mx-12 px-6 md:px-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
        <div>
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan mb-2">POWER SUPPLY</p>
          <p class="font-grotesk text-[14px] text-mid-grey" style="line-height: 1.6;">Lucy Zodion feeder pillars &mdash; DNO-connected, sub-metered between DigiSite and site contractor.</p>
        </div>
        <div>
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan mb-2">CONTENT & SCHEDULING</p>
          <p class="font-grotesk text-[14px] text-mid-grey" style="line-height: 1.6;">Navori QL on BrightSign XT244 players &mdash; remote ad scheduling, proof-of-play reporting, live health monitoring.</p>
        </div>
        <div>
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan mb-2">CONNECTIVITY</p>
          <p class="font-grotesk text-[14px] text-mid-grey" style="line-height: 1.6;">UKConnect managed fixed wireless 5G &mdash; unlimited data, dedicated support. BrightSign local storage ensures screens continue playing if connectivity drops.</p>
        </div>
        <div>
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan mb-2">PROGRAMMATIC MARKETPLACE</p>
          <p class="font-grotesk text-[14px] text-mid-grey" style="line-height: 1.6;">Inventory listed via Vistar Media and Hivestack SSPs &mdash; accessible to every major media buying platform. Broadsign Reach SSP at scale.</p>
        </div>
      </div>
    </div>

    <!-- Community content callout -->
    <div class="reveal text-center mt-12">
      <span class="text-cyan text-lg mb-2 inline-block">&#10022;</span>
      <p class="font-grotesk text-[15px] text-mid-grey mx-auto" style="max-width: 680px;">
        During advertising downtime, DigiSite screens display local community art and public information &mdash; strengthening every planning application and giving back to the neighbourhoods we operate in.
      </p>
    </div>

  </div>
</section>
