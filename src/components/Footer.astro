---
// Footer.astro — DS-12
import LogoSVG from './LogoSVG.astro';

const navLinks = [
  { label: 'Products', href: '#solution' },
  { label: 'Partners', href: '#partnerships' },
  { label: 'Market', href: '#market' },
  { label: 'Roadmap', href: '#roadmap' },
  { label: 'Contact', href: '#contact' },
];
---

<footer class="w-full" style="background: #070F18; border-top: 1px solid rgba(255,255,255,0.06);">
  <div class="max-w-content mx-auto px-6 md:px-12 py-10 md:py-12">

    <!-- Row 1 -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-0 footer-row-1">

      <LogoSVG variant="dark" size="nav" />

      <nav class="flex items-center flex-wrap justify-center gap-4 md:gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-mid-grey hover:text-off-white text-[13px] uppercase tracking-[0.1em] transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-5">
        <span class="text-mid-grey text-[14px] italic">
          The forever-moving canvas.
        </span>
        <div class="flex items-center gap-4">
          <a href="https://www.linkedin.com/in/ben-burns-6aa5a2384/" target="_blank" rel="noopener noreferrer" aria-label="DigiSite on LinkedIn" class="text-mid-grey hover:text-cyan transition-colors duration-200">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/digisitelimited/" target="_blank" rel="noopener noreferrer" aria-label="DigiSite on Instagram" class="text-mid-grey hover:text-cyan transition-colors duration-200">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Divider -->
    <div class="w-full mt-8 mb-6" style="height: 1px; background: rgba(255,255,255,0.04);"></div>

    <!-- Row 2 -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-3 md:gap-0 text-center md:text-left">

      <p class="text-[12px]" style="color: rgba(138,155,176,0.7);">
        &copy; 2026 DigiSite. All rights reserved.&nbsp;&middot;&nbsp;
        <a href="/privacy" class="hover:text-off-white transition-colors duration-200 underline-offset-2">Privacy Policy</a>&nbsp;&middot;&nbsp;
        <a href="/terms" class="hover:text-off-white transition-colors duration-200 underline-offset-2">Terms</a>
      </p>

      <p class="font-mono text-[11px] md:text-right" style="color: rgba(138,155,176,0.6);">
        DigiSite &middot; Liverpool, Merseyside &middot; www.digiscaff.co.uk &middot;
        <a href="mailto:info@digiscaff.co.uk" class="hover:text-cyan transition-colors duration-200">info@digiscaff.co.uk</a>
      </p>

    </div>

  </div>
</footer>
