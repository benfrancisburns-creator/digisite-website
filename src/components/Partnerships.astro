<script>
  // Scheme selector active state
  const panels = document.querySelectorAll('.scheme-panel');
  const selectorItems = document.querySelectorAll('.scheme-selector-item');

  const panelObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        selectorItems.forEach(item => {
          const isActive = (item as HTMLElement).dataset.target === id;
          item.classList.toggle('active', isActive);
          if (isActive) {
            item.classList.remove('text-mid-grey', 'border-transparent');
            item.classList.add('text-off-white');
            // Set border color based on scheme
            const isAmber = id === 'scheme-landlords' || id === 'scheme-events';
            (item as HTMLElement).style.borderBottomColor = isAmber ? '#F5A623' : '#00D4FF';
          } else {
            item.classList.add('text-mid-grey', 'border-transparent');
            item.classList.remove('text-off-white');
            (item as HTMLElement).style.borderBottomColor = 'transparent';
          }
        });
      }
    });
  }, { threshold: 0.2, rootMargin: '-80px 0px -40% 0px' });

  panels.forEach(panel => panelObserver.observe(panel));

  // Selector click scrolls to panel and updates active state
  selectorItems.forEach(item => {
    item.addEventListener('click', () => {
      const targetId = (item as HTMLElement).dataset.target;
      if (targetId) {
        // Immediately update active state on click
        selectorItems.forEach(si => {
          const isActive = (si as HTMLElement).dataset.target === targetId;
          si.classList.toggle('active', isActive);
          if (isActive) {
            si.classList.remove('text-mid-grey', 'border-transparent');
            si.classList.add('text-off-white');
            const isAmber = targetId === 'scheme-landlords' || targetId === 'scheme-events';
            (si as HTMLElement).style.borderBottomColor = isAmber ? '#F5A623' : '#00D4FF';
          } else {
            si.classList.add('text-mid-grey', 'border-transparent');
            si.classList.remove('text-off-white');
            (si as HTMLElement).style.borderBottomColor = 'transparent';
          }
        });

        const target = document.getElementById(targetId);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

</script>
