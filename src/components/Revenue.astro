---
// Revenue.astro — Revenue Potential section
---

<section id="revenue" class="relative bg-section">
  <div class="rule-cyan"></div>

  <div class="max-w-content mx-auto px-6 md:px-12 py-20 md:py-[120px]">

    <!-- Header -->
    <div class="reveal mb-16">
      <p class="font-mono font-semibold text-[18px] text-cyan uppercase tracking-[0.2em] mb-4">REVENUE POTENTIAL</p>
      <h2 class="font-grotesk font-bold text-off-white mb-5" style="font-size: clamp(36px, 5vw, 56px); letter-spacing: -0.02em; max-width: 700px;">
        Market-benchmarked advertising revenue.
      </h2>
      <p class="font-grotesk text-mid-grey text-lg" style="max-width: 640px; line-height: 1.65;">
        DigiSite screens generate advertising revenue across six premium slots per screen on a fortnightly booking cycle &mdash; the same commercial model used by Clear Channel, JCDecaux, and Bauer Media Outdoor.
      </p>
    </div>

    <!-- Model stats -->
    <div class="reveal grid grid-cols-3 gap-6 mb-20">
      <div class="text-center p-6 border border-cyan/[0.15] rounded-md bg-cyan/[0.04]">
        <span class="font-mono font-bold text-[36px] md:text-[48px] text-cyan leading-none">6</span>
        <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-mid-grey mt-2">ADVERTISER SLOTS PER SCREEN</p>
      </div>
      <div class="text-center p-6 border border-cyan/[0.15] rounded-md bg-cyan/[0.04]">
        <span class="font-mono font-bold text-[36px] md:text-[48px] text-cyan leading-none">10s</span>
        <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-mid-grey mt-2">PER SLOT, 60-SECOND LOOP</p>
      </div>
      <div class="text-center p-6 border border-cyan/[0.15] rounded-md bg-cyan/[0.04]">
        <span class="font-mono font-bold text-[28px] md:text-[40px] text-cyan leading-none">14 days</span>
        <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-mid-grey mt-2">UK OOH BOOKING CYCLE</p>
      </div>
    </div>

    <!-- Product revenue cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-16">

      <!-- DigiScaff Revenue -->
      <div class="reveal border border-cyan/[0.15] rounded-md bg-navy overflow-hidden">
        <div class="h-1 bg-cyan/40"></div>
        <div class="p-6 md:p-9">
          <p class="font-mono font-semibold text-[13px] uppercase tracking-[0.2em] text-cyan/60 mb-2">PRODUCT 01</p>
          <h3 class="font-grotesk font-bold text-white text-3xl mb-2" style="letter-spacing: -0.02em;">DigiScaff</h3>
          <p class="font-grotesk text-mid-grey text-[15px] mb-8">Large format digital billboard &mdash; 33m&sup2; at 9,000 nits.</p>

          <!-- Market rates -->
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan mb-4">UK MARKET RATES &mdash; PER SLOT PER FORTNIGHT</p>
          <div class="font-mono text-[13px] mb-8">
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>Liverpool / Manchester</span>
              <span class="text-cyan">&pound;1,000 &ndash; &pound;4,000</span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>Birmingham / Leeds / Sheffield</span>
              <span class="text-cyan">&pound;800 &ndash; &pound;3,000</span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>London outer boroughs</span>
              <span class="text-cyan">&pound;800 &ndash; &pound;2,000</span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-b border-white/[0.06]">
              <span>London prime</span>
              <span class="text-cyan">&pound;5,000 &ndash; &pound;15,000+</span>
            </div>
          </div>

          <!-- Revenue per screen -->
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan mb-4">REVENUE PER SCREEN</p>
          <div class="font-mono text-[13px] mb-8">
            <div class="flex justify-between text-mid-grey/70 uppercase tracking-[0.1em] text-[10px] font-semibold mb-2">
              <span>Scenario</span>
              <span class="flex gap-8"><span class="w-24 text-right">Per Fortnight</span><span class="w-24 text-right">Per Year</span></span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>4 slots at &pound;2,500</span>
              <span class="flex gap-8"><span class="w-24 text-right">&pound;10,000</span><span class="w-24 text-right">&pound;260,000</span></span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>5 slots at &pound;2,500</span>
              <span class="flex gap-8"><span class="w-24 text-right">&pound;12,500</span><span class="w-24 text-right">&pound;325,000</span></span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-b border-white/[0.06] font-semibold">
              <span>6 slots at &pound;2,500</span>
              <span class="flex gap-8"><span class="w-24 text-right text-cyan">&pound;15,000</span><span class="w-24 text-right text-cyan">&pound;390,000</span></span>
            </div>
          </div>

          <!-- Callout -->
          <div class="p-5 border border-cyan/25 rounded-md bg-cyan/[0.06] text-center">
            <span class="font-mono font-bold text-[32px] md:text-[40px] text-cyan leading-none">&pound;390,000</span>
            <p class="font-grotesk text-[14px] text-mid-grey mt-2">Gross annual revenue per screen at full utilisation</p>
          </div>
        </div>
      </div>

      <!-- DigiPerim Revenue -->
      <div class="reveal border border-cyan/[0.15] rounded-md bg-navy overflow-hidden">
        <div class="h-1 bg-amber/40"></div>
        <div class="p-6 md:p-9">
          <p class="font-mono font-semibold text-[13px] uppercase tracking-[0.2em] text-cyan/60 mb-2">PRODUCT 02</p>
          <h3 class="font-grotesk font-bold text-white text-3xl mb-2" style="letter-spacing: -0.02em;">DigiPerim</h3>
          <p class="font-grotesk text-mid-grey text-[15px] mb-8">Premium digital perimeter screens &mdash; a run of inventory at eye level.</p>

          <!-- Market rates -->
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan mb-4">UK MARKET RATES &mdash; COMPARABLE FORMATS</p>
          <div class="font-mono text-[13px] mb-8">
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>Digital bus shelter (regional)</span>
              <span class="text-mid-grey">&pound;200 &ndash; &pound;1,000</span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>Roadside digital 6-sheet</span>
              <span class="text-mid-grey">&pound;250 &ndash; &pound;325</span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>Rail station digital 6-sheet</span>
              <span class="text-mid-grey">&pound;900 &ndash; &pound;1,170</span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-b border-white/[0.06] font-semibold">
              <span>DigiPerim (larger, captive, eye-level)</span>
              <span class="text-amber">&pound;1,000 per slot</span>
            </div>
          </div>

          <!-- Revenue by run length -->
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan mb-4">REVENUE BY RUN LENGTH</p>
          <div class="font-mono text-[13px] mb-8">
            <div class="flex justify-between text-mid-grey/70 uppercase tracking-[0.1em] text-[10px] font-semibold mb-2">
              <span>Configuration</span>
              <span class="flex gap-8"><span class="w-24 text-right">Per Fortnight</span><span class="w-24 text-right">Per Year</span></span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>1 screen (2.88m)</span>
              <span class="flex gap-8"><span class="w-24 text-right">&pound;6,000</span><span class="w-24 text-right">&pound;156,000</span></span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-white/[0.06]">
              <span>3 screens (8.64m run)</span>
              <span class="flex gap-8"><span class="w-24 text-right">&pound;18,000</span><span class="w-24 text-right">&pound;468,000</span></span>
            </div>
            <div class="flex justify-between text-off-white py-2.5 border-t border-b border-white/[0.06] font-semibold">
              <span>5 screens (15m run)</span>
              <span class="flex gap-8"><span class="w-24 text-right text-amber">&pound;30,000</span><span class="w-24 text-right text-amber">&pound;780,000</span></span>
            </div>
          </div>

          <!-- Callout -->
          <div class="p-5 border border-amber/25 rounded-md bg-amber/[0.06] text-center">
            <span class="font-mono font-bold text-[32px] md:text-[40px] text-amber leading-none">&pound;780,000</span>
            <p class="font-grotesk text-[14px] text-mid-grey mt-2">Gross annual revenue per 15m run at full utilisation</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Combined site strip -->
    <div class="reveal border-t border-b border-cyan/10 bg-cyan/[0.04] py-10 -mx-6 md:-mx-12 px-6 md:px-12 mb-16">
      <p class="font-mono font-semibold text-[13px] uppercase tracking-[0.18em] text-cyan mb-6 text-center">COMBINED SITE &mdash; ONE PARTNERSHIP, TWO REVENUE STREAMS</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="text-center p-5 border border-cyan/[0.12] rounded-md bg-navy">
          <p class="font-mono font-semibold text-[11px] uppercase tracking-[0.15em] text-cyan/60 mb-2">DIGISCAFF</p>
          <span class="font-mono font-bold text-[24px] text-off-white">&pound;390,000</span>
          <p class="font-mono text-[11px] text-mid-grey mt-1">&pound;15,000 / fortnight</p>
        </div>
        <div class="flex items-center justify-center">
          <span class="font-mono font-bold text-[20px] text-cyan">+</span>
        </div>
        <div class="text-center p-5 border border-amber/[0.15] rounded-md bg-navy">
          <p class="font-mono font-semibold text-[11px] uppercase tracking-[0.15em] text-amber/60 mb-2">DIGIPERIM (15M RUN)</p>
          <span class="font-mono font-bold text-[24px] text-off-white">&pound;780,000</span>
          <p class="font-mono text-[11px] text-mid-grey mt-1">&pound;30,000 / fortnight</p>
        </div>
      </div>
      <div class="text-center mt-8 p-6 border border-cyan/30 rounded-md bg-cyan/[0.08] max-w-lg mx-auto">
        <span class="font-mono font-bold text-[40px] md:text-[56px] text-cyan leading-none">&pound;1,170,000</span>
        <p class="font-grotesk text-[15px] text-mid-grey mt-3">Gross annual revenue from a single dual-product construction site</p>
      </div>
    </div>

    <!-- Network scale -->
    <div class="reveal mb-12">
      <p class="font-mono font-semibold text-[18px] text-cyan uppercase tracking-[0.2em] mb-4 text-center">THE SCALE OPPORTUNITY</p>
      <p class="font-grotesk text-mid-grey text-[16px] text-center mx-auto mb-10" style="max-width: 600px; line-height: 1.65;">
        Every partner brings a pipeline of sites. Every site adds inventory. Every dual-product deployment multiplies revenue from the same relationship.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="text-center p-6 border border-cyan/[0.12] rounded-md bg-navy">
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mb-3">1 SITE</p>
          <span class="font-mono font-bold text-[28px] md:text-[32px] text-cyan leading-none">&pound;1.17M</span>
          <p class="font-mono text-[11px] text-mid-grey/60 mt-2">per year</p>
        </div>
        <div class="text-center p-6 border border-cyan/[0.15] rounded-md bg-cyan/[0.03]">
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mb-3">4 SITES</p>
          <span class="font-mono font-bold text-[28px] md:text-[32px] text-cyan leading-none">&pound;4.68M</span>
          <p class="font-mono text-[11px] text-mid-grey/60 mt-2">per year</p>
        </div>
        <div class="text-center p-6 border border-cyan/[0.18] rounded-md bg-cyan/[0.04]">
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mb-3">10 SITES</p>
          <span class="font-mono font-bold text-[28px] md:text-[32px] text-cyan leading-none">&pound;11.7M</span>
          <p class="font-mono text-[11px] text-mid-grey/60 mt-2">per year</p>
        </div>
        <div class="text-center p-6 border border-cyan/30 rounded-md bg-cyan/[0.06]">
          <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mb-3">25 SITES</p>
          <span class="font-mono font-bold text-[28px] md:text-[32px] text-cyan leading-none">&pound;29.25M</span>
          <p class="font-mono text-[11px] text-mid-grey/60 mt-2">per year</p>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="reveal text-center">
      <p class="font-mono text-[10px] text-mid-grey/50 mx-auto" style="max-width: 700px; line-height: 1.7;">
        All figures represent gross screen revenue at full slot utilisation before partner revenue share, programmatic SSP fees, and operational costs. Rates benchmarked against published UK OOH market rates for comparable formats. Sources: Excite OOH, media.co.uk, Seen Outdoor, One Day Agency &mdash; January/February 2026.
      </p>
    </div>

  </div>
</section>
