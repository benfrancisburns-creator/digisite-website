---
// Roadmap.astro — DS-10

const phases = [
  {
    num: '01',
    label: 'PHASE 01 · CURRENT',
    name: 'Northern England Pilot',
    desc: 'Deploy 4–16 screens across DigiSite\'s pilot geography. Validate commercial performance, refine operations, gather Route audience data, and establish the first Construction & Development scheme partnerships. The pilot generates the proof of concept that everything else is built on.',
    tags: ['Liverpool', 'Manchester', 'Leeds', 'Sheffield'],
    screens: '4–16',
    isCurrent: true,
  },
  {
    num: '02',
    label: 'PHASE 02',
    name: 'UK City Network',
    desc: 'Scale the proven pilot model across the UK\'s major cities. Expand partner relationships, increase screen count, and grow direct advertiser relationships through the DigiSite booking platform. Each new city replicates the established operational and commercial framework.',
    tags: ['Birmingham', 'Bristol', 'London', 'Edinburgh', 'Glasgow', 'Cardiff'],
    screens: '50–200',
    isCurrent: false,
  },
  {
    num: '03',
    label: 'PHASE 03',
    name: 'European Expansion',
    desc: 'Apply the DigiSite model to European construction markets. The regulatory framework, hardware specifications, and commercial model translate directly. Target markets are selected based on construction activity, DOOH market maturity, and planning environment compatibility.',
    tags: ['Germany', 'Netherlands', 'France', 'Spain', 'Nordics'],
    screens: '500+',
    isCurrent: false,
  },
  {
    num: '04',
    label: 'PHASE 04',
    name: 'Asia Pacific',
    desc: 'The long horizon. Asia Pacific represents the largest construction markets in the world — and some of the most digitally sophisticated advertising environments. DigiSite\'s programmatic infrastructure and operational model are built to scale to this market.',
    tags: ['Singapore', 'Japan', 'Australia', 'UAE'],
    screens: '2,000+',
    isCurrent: false,
    isLast: true,
  },
];
---

<section id="roadmap" class="relative bg-section">
  <div class="rule-cyan"></div>

  <div class="max-w-content mx-auto px-6 md:px-12 py-20 md:py-[120px]">

    <!-- Header -->
    <div class="reveal mb-20">
      <p class="font-mono font-semibold text-[18px] text-cyan uppercase tracking-[0.2em] mb-4">THE ROADMAP</p>
      <h2 class="font-grotesk font-bold text-off-white mb-5" style="font-size: clamp(36px, 5vw, 56px); letter-spacing: -0.02em; max-width: 600px;">
        From Liverpool to the world.
      </h2>
      <p class="font-grotesk text-mid-grey text-lg" style="max-width: 640px; line-height: 1.65;">
        DigiSite's growth strategy is a replication model &mdash; not a reinvention at each stage. Every operational, commercial and regulatory framework built during the pilot is designed to be picked up and deployed in the next city, the next country, the next continent.
      </p>
    </div>

    <!-- Section image -->
    <div class="reveal mb-20 overflow-hidden rounded-md">
      <img
        src="/roadmap-heritage.jpeg"
        alt="DigiSite screen deployed on a heritage building in a UK city with buses and pedestrians"
        width="1536"
        height="1024"
        loading="lazy"
        class="w-full h-[320px] md:h-[500px] object-cover"
      />
    </div>

    <!-- Timeline -->
    <div class="relative mb-16">
      <!-- Desktop connecting line -->
      <div class="hidden md:block absolute top-[26px] left-0 right-0 h-px roadmap-line" style="background: linear-gradient(to right, rgba(0, 212, 255, 0.15), rgba(0, 212, 255, 0.5)); width: 0%;"></div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-0">
        {phases.map((phase) => (
          <div class="reveal relative md:px-4">
            <!-- Mobile connecting line -->
            <div class="absolute left-[26px] top-[52px] bottom-0 w-px bg-cyan/20 md:hidden"></div>

            <!-- Phase marker -->
            <div class:list={[
              'relative z-10 w-[52px] h-[52px] rounded-full border flex items-center justify-center mb-5',
              phase.isCurrent ? 'border-cyan bg-cyan/[0.15]' : 'border-cyan/40 bg-cyan/[0.06]',
            ]}>
              <span class="font-mono font-semibold text-[16px] text-cyan">{phase.num}</span>
            </div>

            <div class="pl-16 md:pl-0">
              <p class="font-mono font-semibold text-[13px] uppercase tracking-[0.2em] text-cyan mb-2">{phase.label}</p>
              <h4 class="font-grotesk font-bold text-off-white mb-3" style="font-size: clamp(20px, 2vw, 24px); letter-spacing: -0.01em;">
                {phase.name}
              </h4>
              <p class="font-grotesk text-[14px] text-mid-grey mb-4" style="line-height: 1.65;">
                {phase.desc}
              </p>

              <!-- Geography tags -->
              <div class="flex flex-wrap gap-1.5 mb-3">
                {phase.tags.map(tag => (
                  <span class:list={[
                    'inline-block px-2.5 py-1 border rounded-sm font-mono text-[10px] text-mid-grey',
                    phase.isLast ? 'border-cyan/[0.12] bg-cyan/[0.04]' : 'border-cyan/20 bg-cyan/[0.06]',
                  ]}>
                    {tag}
                  </span>
                ))}
              </div>

              {phase.isCurrent && (
                <div class="flex items-center gap-2 mt-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"></span>
                  <span class="font-mono font-semibold text-[12px] uppercase tracking-[0.18em] text-cyan">BUILDING NOW</span>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scale visualisation -->
    <div class="reveal bg-cyan/[0.03] border-t border-b border-cyan/[0.08] py-10 -mx-6 md:-mx-12 px-6 md:px-12 mb-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-content mx-auto">
        {phases.map((phase) => (
          <div class="text-center">
            <span class="font-mono font-semibold text-[28px] text-cyan">{phase.screens}</span>
            <p class="font-mono font-semibold text-[12px] uppercase tracking-[0.15em] text-mid-grey mt-1">SCREENS</p>
          </div>
        ))}
      </div>
      <p class="font-mono text-[10px] text-mid-grey/55 text-center mt-4">
        Indicative scale targets. Not financial projections or commitments.
      </p>
    </div>

    <!-- Closing statement -->
    <div class="reveal text-center md:text-center pb-10 md:pb-20">
      <p class="font-grotesk font-bold text-off-white mx-auto mb-4" style="font-size: clamp(26px, 3.5vw, 36px); letter-spacing: -0.02em; max-width: 700px;">
        &ldquo;DigiSite is a forever-moving global canvas.&rdquo;
      </p>
      <p class="font-grotesk text-mid-grey text-lg mx-auto" style="max-width: 560px;">
        Unlocking brand exposure in places traditional billboards cannot reach.
      </p>
    </div>

  </div>
</section>

<script>
  const roadmapLine = document.querySelector('.roadmap-line') as HTMLElement;
  if (roadmapLine) {
    const lineObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          roadmapLine.style.transition = 'width 1s ease-out';
          roadmapLine.style.width = '100%';
          lineObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    lineObserver.observe(roadmapLine.parentElement!);
  }
</script>
