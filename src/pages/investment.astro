---
import PageLayout from '../layouts/PageLayout.astro';
import Opportunity from '../components/Opportunity.astro';
import Market from '../components/Market.astro';
import Revenue from '../components/Revenue.astro';
import Roadmap from '../components/Roadmap.astro';
---

<PageLayout
  title="Investment Opportunity — DigiSite"
  description="DigiSite is creating a new DOOH inventory category on UK construction scaffolding. Market data, revenue potential, and roadmap for investors."
>
  <Opportunity />
  <Market />
  <Revenue />
  <Roadmap />

  <!-- Investor CTA -->
  <section class="bg-navy py-16">
    <div class="max-w-content mx-auto px-6 md:px-12 text-center">
      <p class="font-grotesk font-bold text-[24px] text-off-white mb-4" style="letter-spacing: -0.01em;">
        Interested in investing in DigiSite?
      </p>
      <p class="font-grotesk text-mid-grey text-[16px] mb-8 mx-auto" style="max-width: 560px; line-height: 1.65;">
        Register your interest and we'll be in touch as we progress through our funding rounds.
      </p>
      <a href="/contact?scheme=investment" class="inline-block px-9 py-4 bg-cyan text-navy font-grotesk font-semibold text-[14px] tracking-[0.04em] rounded-sm hover:shadow-[0_0_24px_rgba(0,212,255,0.35)] transition-all duration-200" style="background: #00D4FF;">
        Register Investment Interest &rarr;
      </a>
    </div>
  </section>
</PageLayout>
