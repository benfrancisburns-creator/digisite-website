---
import PageLayout from '../layouts/PageLayout.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Technology from '../components/Technology.astro';
---

<PageLayout
  title="How It Works — DigiSite"
  description="From partnership to live screen: how DigiSite handles planning consent, power infrastructure, hardware installation, content management, and revenue share."
>
  <HowItWorks />
  <Technology />

  <!-- CTA strip -->
  <section class="bg-navy py-16">
    <div class="max-w-content mx-auto px-6 md:px-12 text-center">
      <p class="font-grotesk font-bold text-[24px] text-off-white mb-6" style="letter-spacing: -0.01em;">
        The partner provides the location. DigiSite provides everything else.
      </p>
      <a href="/contact" class="inline-block px-9 py-4 bg-cyan text-navy font-grotesk font-semibold text-[14px] tracking-[0.04em] rounded-sm hover:shadow-[0_0_24px_rgba(0,212,255,0.35)] transition-all duration-200" style="background: #00D4FF;">
        Start the Conversation &rarr;
      </a>
    </div>
  </section>
</PageLayout>
