---
import PageLayout from '../layouts/PageLayout.astro';
import Solution from '../components/Solution.astro';
---

<PageLayout
  title="DigiScaff — LED Screens on Construction Scaffolding | DigiSite"
  description="DigiScaff mounts high-brightness LED advertising screens on construction scaffolding. 9,000 nits, IP66 weatherproofed, deployed across UK cities."
>
  <!-- Page header -->
  <section class="relative bg-navy pt-32 pb-12 md:pt-40 md:pb-16">
    <div class="max-w-content mx-auto px-6 md:px-12">
      <p class="font-mono font-semibold text-[13px] text-cyan uppercase tracking-[0.15em] mb-4">PRODUCT 01</p>
      <h1 class="font-grotesk font-bold text-off-white mb-5" style="font-size: clamp(36px, 5vw, 56px); letter-spacing: -0.02em; max-width: 680px;">
        DigiScaff
      </h1>
      <p class="font-grotesk text-mid-grey text-lg" style="max-width: 620px; line-height: 1.65;">
        High-brightness LED screens mounted on construction scaffolding &mdash; creating premium digital advertising inventory where cities grow.
      </p>
    </div>
  </section>

  <Solution product="digiscaff" />

  <!-- CTA strip -->
  <section class="bg-section py-16">
    <div class="max-w-content mx-auto px-6 md:px-12 text-center">
      <p class="font-grotesk font-bold text-[24px] text-off-white mb-6" style="letter-spacing: -0.01em;">
        Ready to turn your scaffold into a revenue stream?
      </p>
      <div class="flex flex-col md:flex-row items-center justify-center gap-4">
        <a href="/contact?scheme=construction" class="inline-block px-9 py-4 bg-cyan text-navy font-grotesk font-semibold text-[14px] tracking-[0.04em] rounded-sm hover:shadow-[0_0_24px_rgba(0,212,255,0.35)] transition-all duration-200" style="background: #00D4FF;">
          Partner With Us &rarr;
        </a>
        <a href="/digiperim" class="text-mid-grey hover:text-off-white font-grotesk text-[14px] transition-colors duration-200">
          See DigiPerim &rarr;
        </a>
      </div>
    </div>
  </section>
</PageLayout>
