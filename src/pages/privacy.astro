---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import LegalAcceptBar from '../components/LegalAcceptBar.astro';
---

<Base title="Privacy Policy — DigiSite" description="DigiSite Limited privacy policy. How we collect, use, and protect your personal data under UK GDPR.">
  <Nav />

  <main class="pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="max-w-content mx-auto px-6 md:px-12">

      <!-- Header -->
      <p class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">Legal</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-4">Privacy Policy</h1>
      <p class="text-mid-grey text-[15px] mb-12">Last updated: 4 March 2026</p>

      <div class="space-y-12 text-[15px] md:text-[16px] leading-relaxed text-off-white/80">

        <!-- 1. Data Controller -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">1. Data Controller</h2>
          <p>
            <strong class="text-off-white">DigiSite Limited</strong> (Company No. 16616563), registered in England &amp; Wales.<br />
            Registered address: Liverpool, Merseyside, United Kingdom.<br />
            Contact: <a href="mailto:info@digiscaff.co.uk" class="text-cyan hover:underline">info@digiscaff.co.uk</a>
          </p>
        </section>

        <!-- 2. What Data We Collect -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">2. What Data We Collect</h2>
          <p class="mb-3">We collect personal data only through the contact form on this website. The data collected is:</p>
          <ul class="list-disc list-inside space-y-1 pl-2">
            <li>Full name</li>
            <li>Email address</li>
            <li>Company name</li>
            <li>Scheme type (the type of project you are enquiring about)</li>
          </ul>
          <p class="mt-3">We do not use cookies or analytics tools on this website. We use your browser's <strong class="text-off-white">localStorage</strong> to remember that you have accepted our Terms &amp; Conditions. This is a functional, non-tracking mechanism that stays on your device and is never transmitted to our servers.</p>
        </section>

        <!-- 3. How We Collect Data -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">3. How We Collect Data</h2>
          <p>
            Personal data is collected when you voluntarily submit the contact form on our website. No data is collected passively or automatically beyond what is described in Section 6 (Third Parties).
          </p>
        </section>

        <!-- 4. Lawful Basis -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">4. Lawful Basis for Processing</h2>
          <p>
            We process your personal data under <strong class="text-off-white">Article 6(1)(f) of UK GDPR — legitimate interest</strong>. Our legitimate interest is handling business-to-business enquiries received through the contact form and responding to potential partners, advertisers, and clients.
          </p>
        </section>

        <!-- 5. How We Use Your Data -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">5. How We Use Your Data</h2>
          <p>We use the data you provide solely to:</p>
          <ul class="list-disc list-inside space-y-1 pl-2 mt-3">
            <li>Respond to your enquiry</li>
            <li>Follow up on partnership or advertising opportunities</li>
            <li>Maintain a record of business communications</li>
          </ul>
          <p class="mt-3">We will never sell your personal data to third parties.</p>
        </section>

        <!-- 6. Third Parties -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">6. Third-Party Services</h2>
          <p class="mb-3">We use the following third-party services in connection with this website:</p>

          <div class="space-y-4 pl-2">
            <div>
              <p><strong class="text-off-white">Cloudflare (Workers)</strong> — Our contact form submissions are processed via Cloudflare Workers. Cloudflare may process your IP address and request metadata as part of delivering this service. <a href="https://www.cloudflare.com/privacypolicy/" class="text-cyan hover:underline" target="_blank" rel="noopener noreferrer">Cloudflare Privacy Policy</a></p>
            </div>
            <div>
              <p><strong class="text-off-white">Resend</strong> — We use Resend to deliver email notifications when a contact form is submitted. Your name and email address are shared with Resend for this purpose. <a href="https://resend.com/legal/privacy-policy" class="text-cyan hover:underline" target="_blank" rel="noopener noreferrer">Resend Privacy Policy</a></p>
            </div>
            <div>
              <p><strong class="text-off-white">Google Fonts</strong> — This website loads fonts from Google Fonts. When you visit our site, your browser makes a request to Google's servers, which may collect your IP address. <a href="https://policies.google.com/privacy" class="text-cyan hover:underline" target="_blank" rel="noopener noreferrer">Google Privacy Policy</a></p>
            </div>
          </div>
        </section>

        <!-- 7. Data Retention -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">7. Data Retention</h2>
          <p>
            We retain personal data submitted through the contact form for <strong class="text-off-white">12 months</strong> from the date of submission. After this period, your data is permanently deleted unless we have an ongoing business relationship that requires its retention.
          </p>
        </section>

        <!-- 8. Your Rights -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">8. Your Rights Under UK GDPR</h2>
          <p class="mb-3">You have the following rights in relation to your personal data:</p>
          <ul class="list-disc list-inside space-y-1 pl-2">
            <li><strong class="text-off-white">Right of access</strong> — request a copy of the personal data we hold about you</li>
            <li><strong class="text-off-white">Right to rectification</strong> — request correction of inaccurate data</li>
            <li><strong class="text-off-white">Right to erasure</strong> — request deletion of your personal data</li>
            <li><strong class="text-off-white">Right to data portability</strong> — request your data in a structured, machine-readable format</li>
            <li><strong class="text-off-white">Right to object</strong> — object to processing based on legitimate interest</li>
            <li><strong class="text-off-white">Right to restrict processing</strong> — request that we limit how we use your data</li>
          </ul>
          <p class="mt-3">
            To exercise any of these rights, contact us at <a href="mailto:info@digiscaff.co.uk" class="text-cyan hover:underline">info@digiscaff.co.uk</a>. We will respond within one month.
          </p>
        </section>

        <!-- 9. Complaints -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">9. Complaints</h2>
          <p>
            If you are not satisfied with how we handle your personal data, you have the right to lodge a complaint with the <strong class="text-off-white">Information Commissioner's Office (ICO)</strong>:
          </p>
          <p class="mt-3 pl-2">
            Website: <a href="https://ico.org.uk" class="text-cyan hover:underline" target="_blank" rel="noopener noreferrer">ico.org.uk</a><br />
            Telephone: 0303 123 1113
          </p>
        </section>

        <!-- 10. Changes -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">10. Changes to This Policy</h2>
          <p>
            We may update this privacy policy from time to time. Any changes will be posted on this page with an updated "Last updated" date. We encourage you to review this policy periodically.
          </p>
        </section>

      </div>

    </div>
  </main>

  <Footer />
  <LegalAcceptBar otherLabel="Read Terms & Conditions" otherHref="/terms" />
</Base>
