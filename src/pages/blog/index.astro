---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featured = posts.find(p => p.data.featured) || posts[0];
const rest = posts.filter(p => p.id !== featured?.id);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

function getSlug(id: string) {
  return id.replace(/\.md$/, '');
}
---

<Base
  title="Blog — DigiSite | Insights on DOOH & Construction Advertising"
  description="Industry insights, product updates, and thought leadership from DigiSite — the future of digital out-of-home advertising on construction sites."
>
  <Nav />

  <main class="pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="max-w-content mx-auto px-6 md:px-12">

      <!-- Header -->
      <div class="reveal mb-16">
        <p class="font-mono font-semibold text-cyan text-[18px] uppercase tracking-[0.2em] mb-4">INSIGHTS</p>
        <h1 class="font-grotesk font-bold text-off-white mb-4" style="font-size: clamp(36px, 5vw, 52px); letter-spacing: -0.02em; line-height: 1.0;">
          Blog &amp; Articles
        </h1>
        <p class="font-grotesk text-mid-grey text-[16px]" style="line-height: 1.7; max-width: 560px;">
          Thought leadership, industry analysis, and updates from the DigiSite team. Exploring the future of digital advertising on construction infrastructure.
        </p>
      </div>

      {featured && (
        <!-- Featured post -->
        <a href={`/blog/${getSlug(featured.id)}`} class="reveal group block mb-16 border border-cyan/[0.12] rounded-lg overflow-hidden bg-section hover:border-cyan/30 transition-all duration-300">
          <div class="p-8 md:p-12">
            <div class="flex flex-wrap items-center gap-4 mb-5">
              <span class="font-mono font-semibold text-[11px] uppercase tracking-[0.15em] text-navy bg-cyan px-3 py-1 rounded-sm">Featured</span>
              <span class="font-mono text-[12px] uppercase tracking-[0.12em] text-cyan">{featured.data.category}</span>
              <span class="font-mono text-[12px] text-mid-grey">{featured.data.readingTime}</span>
            </div>
            <h2 class="font-grotesk font-bold text-off-white text-[28px] md:text-[36px] leading-tight mb-4 group-hover:text-cyan transition-colors duration-200" style="letter-spacing: -0.02em;">
              {featured.data.title}
            </h2>
            <p class="font-grotesk text-mid-grey text-[16px] mb-6" style="line-height: 1.7; max-width: 700px;">
              {featured.data.description}
            </p>
            <div class="flex items-center gap-4">
              <time class="font-mono text-[12px] text-mid-grey">{formatDate(featured.data.date)}</time>
              <span class="font-grotesk font-medium text-[14px] text-cyan group-hover:translate-x-1 transition-transform duration-200">Read article &rarr;</span>
            </div>
          </div>
        </a>
      )}

      <!-- Post grid -->
      {rest.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
          {rest.map(post => (
            <a href={`/blog/${getSlug(post.id)}`} class="reveal group block border border-cyan/[0.08] rounded-lg bg-section hover:border-cyan/25 transition-all duration-300 hover:-translate-y-1">
              <div class="p-6 md:p-8 flex flex-col h-full">
                <div class="flex items-center gap-3 mb-4">
                  <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-cyan">{post.data.category}</span>
                  <span class="font-mono text-[11px] text-mid-grey/60">&middot;</span>
                  <span class="font-mono text-[11px] text-mid-grey">{post.data.readingTime}</span>
                </div>
                <h3 class="font-grotesk font-bold text-off-white text-[20px] leading-tight mb-3 group-hover:text-cyan transition-colors duration-200" style="letter-spacing: -0.01em;">
                  {post.data.title}
                </h3>
                <p class="font-grotesk text-mid-grey text-[14px] mb-6 flex-grow" style="line-height: 1.65;">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between mt-auto pt-4 border-t border-cyan/[0.06]">
                  <time class="font-mono text-[11px] text-mid-grey">{formatDate(post.data.date)}</time>
                  <span class="font-grotesk font-medium text-[13px] text-cyan group-hover:translate-x-1 transition-transform duration-200">Read &rarr;</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      <!-- CTA -->
      <div class="reveal mt-20 text-center border border-cyan/[0.12] rounded-lg p-10 md:p-14" style="background: rgba(0, 212, 255, 0.02);">
        <p class="font-mono font-semibold text-[13px] text-cyan uppercase tracking-[0.18em] mb-3">STAY INFORMED</p>
        <h2 class="font-grotesk font-bold text-off-white text-[24px] md:text-[32px] mb-4" style="letter-spacing: -0.02em;">
          Want to discuss a partnership?
        </h2>
        <p class="font-grotesk text-mid-grey text-[15px] mb-8 mx-auto" style="max-width: 480px; line-height: 1.7;">
          Whether you're in construction, property, events, or investment — we'd love to hear from you.
        </p>
        <a href="/#contact" class="inline-block px-10 py-4 bg-cyan text-navy font-grotesk font-semibold text-[15px] tracking-[0.04em] rounded-sm hover:shadow-[0_0_24px_rgba(0,212,255,0.35)] transition-all duration-200">
          Get in Touch &rarr;
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Base>
