---
import PageLayout from '../layouts/PageLayout.astro';
import LogoSVG from '../components/LogoSVG.astro';
---

<PageLayout
  title="Page Not Found — DigiSite"
  description="The page you're looking for doesn't exist. Return to DigiSite's homepage."
>
  <section class="relative bg-navy min-h-[80vh] flex items-center">
    <!-- Ambient glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute w-full h-full" style="background: radial-gradient(ellipse 40% 30% at 50% 50%, rgba(0, 212, 255, 0.06) 0%, transparent 100%);"></div>
    </div>

    <div class="relative z-10 max-w-content mx-auto px-6 md:px-12 w-full text-center py-20">
      <!-- Large 404 -->
      <p class="font-mono font-bold text-cyan leading-none mb-8" style="font-size: clamp(100px, 20vw, 200px); letter-spacing: -0.04em; opacity: 0.15;">
        404
      </p>

      <h1 class="font-grotesk font-bold text-off-white mb-4" style="font-size: clamp(28px, 4vw, 44px); letter-spacing: -0.02em;">
        This location isn't in the network.
      </h1>

      <p class="font-grotesk text-mid-grey text-[16px] mb-10 mx-auto" style="max-width: 480px; line-height: 1.65;">
        The page you're looking for doesn't exist or has been moved. Let's get you back to somewhere useful.
      </p>

      <div class="flex flex-col md:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-block px-9 py-4 bg-cyan text-navy font-grotesk font-semibold text-[14px] tracking-[0.04em] rounded-sm hover:shadow-[0_0_24px_rgba(0,212,255,0.35)] transition-all duration-200" style="background: #00D4FF;">
          Back to Homepage &rarr;
        </a>
        <a href="/contact" class="text-mid-grey hover:text-off-white font-grotesk text-[14px] transition-colors duration-200">
          Get in touch &rarr;
        </a>
      </div>
    </div>
  </section>
</PageLayout>
