---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Terms & Conditions — DigiSite" description="DigiSite Limited terms and conditions of use. Disclaimers, liability, and governing law.">
  <Nav />

  <main class="pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="max-w-content mx-auto px-6 md:px-12">

      <!-- Header -->
      <p class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">Legal</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-4">Terms &amp; Conditions</h1>
      <p class="text-mid-grey text-[15px] mb-12">Last updated: 4 March 2026</p>

      <div class="space-y-12 text-[15px] md:text-[16px] leading-relaxed text-off-white/80">

        <!-- 1. About This Website -->
        <section>
          <h2 class="font-mono text-cyan text-[13px] uppercase tracking-[0.15em] mb-4">1. About This Website</h2>
          <p>
            This website is operated by <strong class="text-off-white">DigiSite Limited</strong> (Company No. 16616563), a company registered in England &amp; Wales. Registered address: Liverpool, Merseyside, United Kingdom. The company is currently dormant.
          </p>
          <p class="mt-3">
            By accessing and using this website, you agree to be bound by these terms and conditions. If you do not agree, please do not use the site.
          </p>
